{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@liquid-ops/types": ["packages/types/src"],
      "@liquid-ops/config/*": ["packages/config/*"],
      "@liquid-ops/ui/*": ["packages/ui/src/*"]
    }
  }
}
